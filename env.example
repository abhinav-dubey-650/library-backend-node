NODE_ENV=development
PORT=8080

# PostgreSQL (Neon) — node-postgres connection string
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Auth — MUST match the original Java backend secret so existing tokens/passwords keep working.
APP_TOKEN_SECRET=change-me-to-the-same-32plus-char-secret-as-java
APP_ADMIN_PIN=560059

# CORS — comma-separated origins
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

LOG_LEVEL=info

# WhatsApp (Phase 2 — disabled by default)
WHATSAPP_ENABLED=false
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=
WHATSAPP_API_VERSION=v21.0
WHATSAPP_BASE_URL=https://graph.facebook.com
WHATSAPP_RATE_LIMIT_PER_SECOND=80
WHATSAPP_RATE_LIMIT_PER_DAY=10000
WHATSAPP_MONTHLY_COLLECTION_RECIPIENTS=
WHATSAPP_QUEUE_RETENTION_DAYS=10
