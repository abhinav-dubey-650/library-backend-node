NODE_ENV=development
PORT=8080

# PostgreSQL — same DB as the Java backend (Java JDBC format also works)
DATABASE_URL=jdbc:postgresql://host/dbname?sslmode=require
DATABASE_USERNAME=your_username
DATABASE_PASSWORD=your_password
# Or a single node-style URL:
# DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Auth — MUST match the Java backend for token/password compatibility
APP_TOKEN_SECRET=your-secret-here
APP_ADMIN_PIN=560059

# CORS — comma-separated allowed origins
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

LOG_LEVEL=info

# WhatsApp (disabled by default — set WHATSAPP_ENABLED=true to enable)
WHATSAPP_ENABLED=false
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=
WHATSAPP_API_VERSION=v21.0
WHATSAPP_BASE_URL=https://graph.facebook.com
WHATSAPP_RATE_LIMIT_PER_SECOND=80
WHATSAPP_RATE_LIMIT_PER_DAY=10000
WHATSAPP_MONTHLY_COLLECTION_RECIPIENTS=
WHATSAPP_QUEUE_RETENTION_DAYS=10
